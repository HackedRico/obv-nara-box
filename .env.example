# LLM Backend — switch with zero code changes
# Options: featherless | ollama | claude
LLM_BACKEND=featherless

# Featherless (OpenAI-compatible — https://featherless.ai/models )
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=microsoft/Phi-4-mini-instruct

# Ollama (local — set LLM_BACKEND=ollama; must match `ollama list`)
OLLAMA_MODEL=qwen2.5-coder:7b-instruct

# Claude API (set LLM_BACKEND=claude — get key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
