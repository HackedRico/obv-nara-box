# LLM Backend — switch with zero code changes
# Options: ollama | claude | featherless
LLM_BACKEND=ollama

# Ollama (local, free — must match `ollama list`, e.g. qwen2.5-coder:7b-instruct)
OLLAMA_MODEL=qwen2.5-coder:7b-instruct

# Claude API (demo quality — get key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Featherless (OpenAI-compatible, open-source models)
# FEATHERLESS_API_KEY=your-key-here
# FEATHERLESS_MODEL=meta-llama/Llama-3.3-70B-Instruct
